    #[test]
    #[should_panic]
    fn test_validate_execute_from_outside_does_not_bypass_valid_after() {
        let registry = deploy_registry();
        let account = deploy_account(registry);
        let dispatcher = ICavosValidateTestDispatcher { contract_address: account };

        let register_signature = build_signature(
            @valid_signed_jwt(),
            valid_rsa_data(),
            9999999999,
            GOOGLE_ISS,
            1700000100,
            65,
            86,
            22,
            159,
            10,
            8,
            27,
            44,
            12,
        );

        start_cheat_block_timestamp(account, 1700000000);
        start_cheat_transaction_hash(account, 0x123);
        start_cheat_signature(account, register_signature.span());
        dispatcher.__validate__(array![]);

        let empty_calldata: Array<felt252> = array![];
        let calls = array![
            Call {
                to: account, selector: selector!("execute_from_outside_v2"),
                calldata: empty_calldata.span(),
            },
        ];

        let session_sig = session_signature();
        start_cheat_signature(account, session_sig.span());
        dispatcher.__validate__(calls);
    }
