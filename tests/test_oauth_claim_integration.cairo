    fn byte_array_to_bytes(data: @ByteArray) -> Array<u8> {
        let mut result: Array<u8> = array![];
        let mut i: usize = 0;
        while i != data.len() {
            result.append(data.at(i).unwrap());
            i += 1;
        }
        result
    }

    fn pack_byte_array_to_felts(data: @ByteArray) -> Array<felt252> {
        let mut packed: Array<felt252> = array![];
        let mut i: usize = 0;
        while i < data.len() {
            let remaining = data.len() - i;
            let chunk_len = if remaining >= 31 { 31 } else { remaining };
            let mut chunk = 0_felt252;
            let mut j: usize = 0;
            while j < chunk_len {
                let byte: u8 = data.at(i + j).unwrap();
                chunk = chunk * 256 + byte.into();
                j += 1;
            }
            packed.append(chunk);
            i += chunk_len;
        }
        packed
    }

