    fn build_signature(
        signed_jwt: @ByteArray,
        rsa_data: Array<felt252>,
        jwt_exp_felt: felt252,
        jwt_iss: felt252,
        valid_after: felt252,
        sub_offset: usize,
        nonce_offset: usize,
        kid_offset: usize,
        exp_offset: usize,
        exp_len: usize,
        iss_offset: usize,
        iss_len: usize,
        aud_offset: usize,
        aud_len: usize,
    ) -> Array<felt252> {
        let mut signature = array![
            OAUTH_SIG_MAGIC,
            SIG_R,
            SIG_S,
            SESSION_KEY,
            VALID_UNTIL,
            RANDOMNESS,
            JWT_SUB,
            JWT_NONCE,
            jwt_exp_felt,
            kid_hash(),
            jwt_iss,
            SALT,
            WALLET_NAME,
            sub_offset.into(),
            10,
            nonce_offset.into(),
            65,
            kid_offset.into(),
            8,
            exp_offset.into(),
            exp_len.into(),
            iss_offset.into(),
            iss_len.into(),
            aud_offset.into(),
            aud_len.into(),
            GARAGA_RSA_LEN,
        ];
        signature.append_span(rsa_data.span());
        signature.append(signed_jwt.len().into());
        let packed_jwt = pack_byte_array_to_felts(signed_jwt);
        signature.append_span(packed_jwt.span());
        signature.append(valid_after);
        signature.append(0); // allowed_contracts_root
        signature.append(10); // max_calls_per_tx
        signature.append(0); // spending_policies_count
        signature
    }

    fn session_signature() -> Array<felt252> {
        array![SESSION_SIG_MAGIC, SIG_R, SIG_S, SESSION_KEY]
    }

    fn run_validate(signature: Array<felt252>, timestamp: u64) {
        let registry = deploy_registry();
        let account = deploy_account(registry);
        let dispatcher = ICavosValidateTestDispatcher { contract_address: account };
        start_cheat_block_timestamp(account, timestamp);
        start_cheat_transaction_hash(account, 0x123);
        start_cheat_signature(account, signature.span());
        dispatcher.__validate__(array![]);
    }

    #[test]
    fn test_validate_accepts_valid_oauth_fixture() {
        let signature = build_signature(
            @valid_signed_jwt(),
            valid_rsa_data(),
            9999999999,
            GOOGLE_ISS,
            0,
            65,
            86,
            22,
            159,
            10,
            8,
            27,
            44,
            12,
        );
        run_validate(signature, 1700000000);
    }

